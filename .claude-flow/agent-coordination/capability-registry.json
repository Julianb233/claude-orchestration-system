  "taskToCapabilityMapping": {
    "implement_feature": {
      "requiredCapabilities": ["coding"],
      "preferredAgents": ["typescript-pro", "python-pro", "frontend-developer"],
      "minComplexity": "medium"
    },
    "fix_bug": {
      "requiredCapabilities": ["debugging", "coding"],
      "preferredAgents": ["debugger", "typescript-pro", "python-pro"],
      "minComplexity": "medium"
    },
    "design_architecture": {
      "requiredCapabilities": ["system-design", "api-design"],
      "preferredAgents": ["backend-architect", "database-architect"],
      "minComplexity": "expert"
    },
    "security_audit": {
      "requiredCapabilities": ["security", "code-review"],
      "preferredAgents": ["security-auditor"],
      "minComplexity": "expert"
    },
    "write_tests": {
      "requiredCapabilities": ["testing", "coding"],
      "preferredAgents": ["test-automator", "tdd-orchestrator"],
      "minComplexity": "medium"
    },
    "optimize_performance": {
      "requiredCapabilities": ["performance", "profiling"],
      "preferredAgents": ["performance-engineer", "database-optimizer"],
      "minComplexity": "high"
    },
    "create_documentation": {
