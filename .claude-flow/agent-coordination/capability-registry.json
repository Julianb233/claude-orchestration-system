  "matchingAlgorithm": {
    "weights": {
      "primaryCapabilityMatch": 3.0,
      "secondaryCapabilityMatch": 1.5,
      "specializationMatch": 2.0,
      "complexityFit": 1.0,
      "currentLoad": -0.5,
      "recentSuccess": 0.8
    },
    "minimumScore": 0.5,
    "fallbackBehavior": "use_general_purpose"
  }
}
