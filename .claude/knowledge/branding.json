{
  "version": "1.0",
  "description": "Julian's default branding settings for document generation",
  "brand": {
    "name": "AI Acrobatics Orchestra",
    "tagline": "Autonomous AI Agent Orchestration",
    "logo": null
  },
  "colors": {
    "primary": "#2563eb",
    "secondary": "#7c3aed",
    "accent": "#06b6d4",
    "background": "#ffffff",
    "text": "#1f2937",
    "muted": "#6b7280"
  },
  "typography": {
    "headingFont": "Inter, system-ui, sans-serif",
    "bodyFont": "Inter, system-ui, sans-serif",
    "codeFont": "JetBrains Mono, monospace"
  },
  "documents": {
    "header": {
      "show": true,
      "includeLogo": true,
      "includeDate": true
    },
    "footer": {
      "show": true,
      "text": "Generated by AI Acrobatics Orchestra",
      "includePageNumbers": true
    },
    "styles": {
      "headingColor": "#2563eb",
      "linkColor": "#7c3aed",
      "codeBackground": "#f3f4f6",
      "borderColor": "#e5e7eb"
    }
  },
  "pdf": {
    "pageSize": "letter",
    "margins": {
      "top": "1in",
      "bottom": "1in",
      "left": "1in",
      "right": "1in"
    },
    "template": "professional"
  },
  "templates": {
    "guide": {
      "titlePrefix": "How-To Guide:",
      "includeTableOfContents": true,
      "includeTroubleshooting": true
    },
    "support": {
      "titlePrefix": "Support:",
      "includeContactInfo": true,
      "contactEmail": null
    },
    "ebook": {
      "chapterStyle": "numbered",
      "includeIndex": true
    }
  }
}
