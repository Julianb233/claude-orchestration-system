{
  "name": "Multi-Channel Notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "notify",
        "responseMode": "responseNode"
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "id": "webhook-trigger",
      "name": "Webhook Trigger"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "version": 2 },
          "conditions": [
            {
              "leftValue": "={{ $json.channels }}",
              "rightValue": "",
              "operator": { "type": "array", "operation": "notEmpty" }
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [450, 300],
      "id": "check-channels",
      "name": "Has Channels"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "version": 2 },
          "conditions": [
            {
              "leftValue": "={{ $json.channels.includes('email') }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [650, 200],
      "id": "check-email",
      "name": "Email Enabled"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "version": 2 },
          "conditions": [
            {
              "leftValue": "={{ $json.channels.includes('slack') }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [650, 400],
      "id": "check-slack",
      "name": "Slack Enabled"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "={{ $json.subject || 'Notification' }}",
        "emailType": "text",
        "message": "={{ $json.message }}"
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [850, 150],
      "id": "send-email",
      "name": "Send Email",
      "credentials": {
        "gmailOAuth2": {
          "id": "GMAIL_CREDENTIALS_ID",
          "name": "Gmail"
        }
      }
    },
    {
      "parameters": {
        "channel": "={{ $json.slackChannel || '#notifications' }}",
        "text": "={{ $json.message }}",
        "otherOptions": {}
      },
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [850, 350],
      "id": "send-slack",
      "name": "Send Slack",
      "credentials": {
        "slackApi": {
          "id": "SLACK_CREDENTIALS_ID",
          "name": "Slack"
        }
      }
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll",
        "options": {}
      },
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1050, 300],
      "id": "merge-results",
      "name": "Merge Results"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { success: true, sent: { email: $('Send Email').item ? true : false, slack: $('Send Slack').item ? true : false } } }}"
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1250, 300],
      "id": "respond",
      "name": "Respond"
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [[{ "node": "Has Channels", "type": "main", "index": 0 }]]
    },
    "Has Channels": {
      "main": [
        [
          { "node": "Email Enabled", "type": "main", "index": 0 },
          { "node": "Slack Enabled", "type": "main", "index": 0 }
        ]
      ]
    },
    "Email Enabled": {
      "main": [
        [{ "node": "Send Email", "type": "main", "index": 0 }],
        [{ "node": "Merge Results", "type": "main", "index": 0 }]
      ]
    },
    "Slack Enabled": {
      "main": [
        [{ "node": "Send Slack", "type": "main", "index": 0 }],
        [{ "node": "Merge Results", "type": "main", "index": 1 }]
      ]
    },
    "Send Email": {
      "main": [[{ "node": "Merge Results", "type": "main", "index": 0 }]]
    },
    "Send Slack": {
      "main": [[{ "node": "Merge Results", "type": "main", "index": 1 }]]
    },
    "Merge Results": {
      "main": [[{ "node": "Respond", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false
}
