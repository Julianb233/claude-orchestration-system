{
  "name": "VAPI Outbound Call",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "vapi-call",
        "responseMode": "responseNode"
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "webhookId": "vapi-call-webhook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.vapi.ai/call",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ phoneNumberId: $env.VAPI_PHONE_NUMBER_ID, assistantId: $env.VAPI_ASSISTANT_ID, customer: { number: $json.phone, name: $json.name || '' }, type: 'outboundPhoneCall' }) }}"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 300],
      "id": "vapi-create-call",
      "name": "Create VAPI Call",
      "credentials": {
        "httpHeaderAuth": {
          "id": "VAPI_CREDENTIALS_ID",
          "name": "VAPI API Key"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { success: true, callId: $json.id, status: $json.status } }}"
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [650, 300],
      "id": "respond-success",
      "name": "Respond Success"
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [[{ "node": "Create VAPI Call", "type": "main", "index": 0 }]]
    },
    "Create VAPI Call": {
      "main": [[{ "node": "Respond Success", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false
}
